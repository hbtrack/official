{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HB Track — Mini Design System (APP)",
  "version": "1.0.0",
  "lastUpdated": "2026-01-07",
  "description": "Sistema de design canônico do HB Track para aplicações internas (dashboard/app)",
  
  "principles": {
    "core": [
      {
        "name": "Densidade > Impacto",
        "description": "Priorizar informação e funcionalidade sobre elementos visuais decorativos"
      },
      {
        "name": "Consistência > Liberdade",
        "description": "Seguir padrões estabelecidos ao invés de criar variações"
      },
      {
        "name": "Dados Primeiro",
        "description": "O conteúdo e os dados são mais importantes que o design"
      },
      {
        "name": "Nada cresce sem permissão",
        "description": "Elementos não podem ultrapassar limites estabelecidos sem justificativa forte"
      }
    ],
    "philosophy": "O design não chama atenção. Ele entrega controle."
  },

  "typography": {
    "description": "Nunca usar tokens de marketing no app. Hierarquia por peso e cor, não por tamanho.",
    "maxTitleSize": "18px",
    "scale": {
      "xs": {
        "token": "--app-text-xs",
        "size": "12px",
        "lineHeight": "16px",
        "use": "Texto secundário, labels, meta informações"
      },
      "sm": {
        "token": "--app-text-sm",
        "size": "14px",
        "lineHeight": "20px",
        "use": "Texto base do aplicativo"
      },
      "base": {
        "token": "--app-text-base",
        "size": "16px",
        "lineHeight": "22px",
        "use": "Título de seção"
      },
      "lg": {
        "token": "--app-text-lg",
        "size": "18px",
        "lineHeight": "24px",
        "use": "Título de página (máximo permitido)"
      }
    },
    "rules": [
      "Nenhum título interno > 18px",
      "Hierarquia por peso e cor, não por tamanho",
      "Nunca usar text-title-* (reservado para landing)",
      "Nunca usar text-2xl+ no app"
    ],
    "classes": {
      "appTitle": {
        "className": "app-title",
        "fontSize": "var(--app-text-lg)",
        "lineHeight": "var(--app-text-lg-lh)",
        "fontWeight": "600",
        "use": "Títulos de página/tela"
      },
      "appSubtitle": {
        "className": "app-subtitle",
        "fontSize": "var(--app-text-sm)",
        "lineHeight": "var(--app-text-sm-lh)",
        "color": "var(--color-gray-500)",
        "use": "Subtítulos e descrições"
      }
    }
  },

  "spacing": {
    "description": "Vertical < Horizontal. Proibido p-6 em telas internas.",
    "scale": {
      "xs": {
        "token": "--app-space-xs",
        "value": "4px"
      },
      "sm": {
        "token": "--app-space-sm",
        "value": "8px"
      },
      "md": {
        "token": "--app-space-md",
        "value": "12px"
      },
      "lg": {
        "token": "--app-space-lg",
        "value": "16px"
      },
      "xl": {
        "token": "--app-space-xl",
        "value": "20px"
      }
    },
    "rules": [
      "Vertical < Horizontal",
      "Proibido p-6 em telas internas",
      "Usar --app-space-lg (16px) como padding padrão de cards"
    ]
  },

  "components": {
    "Button": {
      "path": "src/components/ui/Button.tsx",
      "specs": {
        "height": "h-9",
        "fontSize": "text-sm",
        "iconSize": "h-4 w-4",
        "variants": ["primary", "secondary", "ghost", "outline", "danger", "success"]
      },
      "rules": [
        "Nunca text-base+",
        "Nunca h-11+",
        "Input não pode ser maior que botão"
      ]
    },
    "AppCard": {
      "path": "src/components/app/AppCard.tsx",
      "description": "Container de informação padronizado",
      "specs": {
        "className": "app-card",
        "padding": "var(--app-space-lg) (16px)",
        "titleSize": "text-sm",
        "metaSize": "text-xs",
        "densities": ["compact", "default"]
      },
      "rules": [
        "Sempre usar <AppCard />",
        "Padding controlado via componente",
        "Título text-sm",
        "Meta text-xs",
        "Card nunca é hero",
        "Proibido p-* direto no JSX",
        "Proibido títulos grandes"
      ],
      "usage": {
        "props": ["title", "meta", "actions", "footer", "density"],
        "example": "<AppCard title=\"Equipe Sub-16\" meta=\"12 atletas\" actions={<Button size=\"sm\">Abrir</Button>}>Conteúdo</AppCard>"
      }
    },
    "AppEmptyState": {
      "path": "src/components/app/AppEmptyState.tsx",
      "description": "Estado inicial / ausência de dados",
      "specs": {
        "titleSize": "text-sm",
        "descriptionSize": "text-xs",
        "iconSize": "h-5 w-5",
        "maxCTA": 1
      },
      "rules": [
        "Compacto",
        "Ícone pequeno ou ilustração leve",
        "1 CTA no máximo",
        "Nunca ocupar tela inteira",
        "Não usar py-16, text-2xl",
        "Não centralizar página inteira sem critério"
      ],
      "usage": {
        "props": ["icon", "title", "description", "action", "align"],
        "example": "<AppEmptyState icon={<Users className=\"h-5 w-5\" />} title=\"Nenhuma equipe\" description=\"Crie sua primeira equipe\" action={<Button>Criar</Button>} />"
      }
    },
    "AppInput": {
      "path": "src/components/app/AppInput.tsx",
      "description": "Input padronizado com mesma altura do botão",
      "specs": {
        "height": "h-9",
        "fontSize": "text-sm",
        "labelSize": "text-xs",
        "helperSize": "text-xs",
        "errorSize": "text-xs"
      },
      "rules": [
        "h-9 (mesma altura do Button)",
        "text-sm",
        "Label text-xs",
        "Helper/Error text-xs",
        "Input maior que botão = erro",
        "Não usar h-11, py-3, text-base",
        "Não criar label manual em cada tela",
        "Não misturar alturas de input e botão"
      ],
      "usage": {
        "props": ["label", "helperText", "error", "fullWidth"],
        "example": "<AppInput label=\"Nome da equipe\" placeholder=\"Ex: Sub-16\" helperText=\"Identificação da equipe\" />"
      }
    }
  },

  "patterns": {
    "pageTitle": {
      "description": "Padrão único para títulos de página",
      "template": "<h1 className=\"text-lg font-semibold\">Título</h1>\n<p className=\"text-sm text-muted-foreground\">Descrição opcional</p>",
      "forbidden": ["text-title-*", "text-2xl+"]
    },
    "tables": {
      "rowHeight": "h-10 máx",
      "headerSize": "text-xs uppercase",
      "actions": "ícone, não botão grande",
      "principle": "Mais colunas > menos espaçamento"
    },
    "visualStates": {
      "primary": "ação",
      "success": "verde/vermelho = feedback",
      "forbidden": ["gradiente decorativo", "sombra pesada"]
    }
  },

  "codeOrganization": {
    "structure": {
      "ui": {
        "path": "src/components/ui/",
        "description": "Átomos (Button, Input, Dialog)"
      },
      "app": {
        "path": "src/components/app/",
        "description": "Contratos do produto (AppCard, AppEmptyState, AppInput)"
      }
    },
    "principle": "UI = peças, APP = regras"
  },

  "cssTokens": {
    "typography": {
      "--app-text-xs": "12px",
      "--app-text-xs-lh": "16px",
      "--app-text-sm": "14px",
      "--app-text-sm-lh": "20px",
      "--app-text-base": "16px",
      "--app-text-base-lh": "22px",
      "--app-text-lg": "18px",
      "--app-text-lg-lh": "24px"
    },
    "spacing": {
      "--app-space-xs": "4px",
      "--app-space-sm": "8px",
      "--app-space-md": "12px",
      "--app-space-lg": "16px",
      "--app-space-xl": "20px"
    }
  },

  "cssClasses": {
    "app-title": {
      "fontSize": "var(--app-text-lg)",
      "lineHeight": "var(--app-text-lg-lh)",
      "fontWeight": "600"
    },
    "app-subtitle": {
      "fontSize": "var(--app-text-sm)",
      "lineHeight": "var(--app-text-sm-lh)",
      "color": "var(--color-gray-500)"
    },
    "app-card": {
      "padding": "var(--app-space-lg)",
      "borderRadius": "0.75rem"
    },
    "app-card-header": {
      "display": "flex",
      "alignItems": "flex-start",
      "justifyContent": "space-between",
      "gap": "var(--app-space-md)",
      "marginBottom": "var(--app-space-md)"
    },
    "app-card-title": {
      "fontSize": "var(--app-text-sm)",
      "fontWeight": "600",
      "lineHeight": "var(--app-text-sm-lh)"
    },
    "app-card-meta": {
      "fontSize": "var(--app-text-xs)",
      "color": "var(--color-gray-500)",
      "lineHeight": "var(--app-text-xs-lh)"
    },
    "app-card-body": {
      "fontSize": "var(--app-text-sm)"
    },
    "app-card-footer": {
      "marginTop": "var(--app-space-md)",
      "paddingTop": "var(--app-space-md)",
      "borderTop": "1px solid var(--color-gray-200)"
    }
  },

  "globalCSS": {
    "body": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--app-text-sm)",
      "lineHeight": "var(--app-text-sm-lh)",
      "description": "Define 14px como texto base do app"
    }
  },

  "checklist": {
    "beforeCommit": [
      {
        "question": "Algum texto > 18px?",
        "action": "Corrigir para escala app"
      },
      {
        "question": "Algum p-6?",
        "action": "Usar AppCard ou padding menor"
      },
      {
        "question": "Card sem AppCard?",
        "action": "Refatorar para usar AppCard"
      },
      {
        "question": "Estado vazio custom?",
        "action": "Usar AppEmptyState"
      },
      {
        "question": "Input maior que botão?",
        "action": "Forçar h-9 em ambos"
      }
    ]
  },

  "antiPatterns": {
    "forbidden": [
      {
        "pattern": "text-title-* no app",
        "reason": "Reservado para landing pages"
      },
      {
        "pattern": "text-2xl+ no app",
        "reason": "Quebra densidade"
      },
      {
        "pattern": "p-6 em telas internas",
        "reason": "Padding muito grande, usar p-4 (--app-space-lg)"
      },
      {
        "pattern": "h-11+ em botões",
        "reason": "Padrão é h-9"
      },
      {
        "pattern": "text-base+ em botões",
        "reason": "Padrão é text-sm"
      },
      {
        "pattern": "Card sem AppCard",
        "reason": "Perde consistência"
      },
      {
        "pattern": "Estado vazio custom",
        "reason": "Usar AppEmptyState"
      },
      {
        "pattern": "Input maior que botão",
        "reason": "Quebra alinhamento visual"
      },
      {
        "pattern": "Gradiente decorativo",
        "reason": "App não é landing"
      },
      {
        "pattern": "Sombra pesada",
        "reason": "Densidade > impacto"
      },
      {
        "pattern": "py-16 em estado vazio",
        "reason": "Ocupa tela inteira desnecessariamente"
      },
      {
        "pattern": "label manual em cada tela",
        "reason": "Usar AppInput com prop label"
      }
    ]
  },

  "migrationGuide": {
    "fromOldToNew": {
      "Button": {
        "before": "h-11 text-base",
        "after": "h-9 text-sm"
      },
      "Card": {
        "before": "<div className=\"p-6\">",
        "after": "<AppCard>"
      },
      "Title": {
        "before": "text-2xl",
        "after": "text-lg (app-title)"
      },
      "Input": {
        "before": "h-11 py-3",
        "after": "<AppInput /> (h-9)"
      },
      "EmptyState": {
        "before": "custom com py-16",
        "after": "<AppEmptyState />"
      }
    }
  },

  "designDecisions": {
    "whyDensity": "Profissionais de esporte precisam de informação rápida, não de elementos decorativos grandes",
    "why14px": "14px é o tamanho ideal para leitura de dados em dashboards profissionais",
    "why18pxMax": "Títulos maiores roubam atenção dos dados. No app, dados > hierarquia visual",
    "whyNoP6": "p-6 (24px) é excessivo para densidade. p-4 (16px) é suficiente",
    "whyH9": "h-9 (36px) é a altura ideal para densidade sem comprometer acessibilidade"
  },

  "accessibility": {
    "notes": [
      "14px base mantém legibilidade",
      "h-9 mantém área de toque adequada (36px)",
      "Contraste mantido via cores do design system",
      "Line-height calculado para legibilidade"
    ]
  },

  "implementation": {
    "globalCSSPath": "src/styles/globals.css",
    "componentsPath": "src/components/app/",
    "requiredFiles": [
      "src/components/app/AppCard.tsx",
      "src/components/app/AppEmptyState.tsx",
      "src/components/app/AppInput.tsx",
      "src/components/ui/Button.tsx"
    ]
  },

  "validation": {
    "automated": {
      "eslint": "Adicionar regras para detectar text-2xl+, h-11+, p-6 em app",
      "typescript": "Tipos forçam uso de AppCard, AppEmptyState, AppInput"
    },
    "manual": "Checklist de revisão antes de cada commit"
  },

  "examples": {
    "goodPatterns": [
      {
        "name": "Card de Equipe",
        "code": "<AppCard title=\"Sub-16 Feminino\" meta=\"18 atletas\" actions={<Button size=\"sm\">Abrir</Button>}><p className=\"text-sm\">Última atualização: hoje</p></AppCard>"
      },
      {
        "name": "Formulário de Cadastro",
        "code": "<form className=\"space-y-4\">\n  <AppInput label=\"Nome\" placeholder=\"Digite o nome\" />\n  <AppInput label=\"Email\" type=\"email\" helperText=\"Será usado para login\" />\n  <Button className=\"w-full\">Cadastrar</Button>\n</form>"
      },
      {
        "name": "Lista Vazia",
        "code": "<AppEmptyState icon={<Users className=\"h-5 w-5\" />} title=\"Nenhum atleta cadastrado\" description=\"Adicione atletas para começar\" action={<Button size=\"sm\">Adicionar Atleta</Button>} />"
      },
      {
        "name": "Título de Página",
        "code": "<div className=\"space-y-1 mb-6\">\n  <h1 className=\"app-title\">Estatísticas da Equipe</h1>\n  <p className=\"app-subtitle\">Acompanhe o desempenho dos atletas</p>\n</div>"
      }
    ],
    "badPatterns": [
      {
        "name": "Card Customizado (EVITAR)",
        "code": "<div className=\"p-6 rounded-lg border\">\n  <h3 className=\"text-2xl font-bold\">Título Grande</h3>\n</div>",
        "reason": "Usar AppCard, não p-6, não text-2xl"
      },
      {
        "name": "Input Grande (EVITAR)",
        "code": "<input className=\"h-11 py-3 text-base\" />",
        "reason": "Usar AppInput com h-9"
      },
      {
        "name": "Botão Grande (EVITAR)",
        "code": "<button className=\"h-12 text-lg\">Salvar</button>",
        "reason": "Usar Button com h-9 text-sm"
      }
    ]
  },

  "modules": {
    "training": {
      "route": "/training",
      "title": "Planejamento, Execução e Avaliação de Treinos",
      "description": "Centro estratégico para o treinador, unificando planejamento tático e físico, execução de sessões e avaliação qualitativa/quantitativa",
      
      "objectives": [
        "Planejamento tático e físico",
        "Execução de sessões",
        "Avaliação qualitativa e quantitativa",
        "Organização de micro/meso/trimestres",
        "Acesso rápido a recursos técnicos",
        "Feedback e comunicação com atletas"
      ],

      "layoutStructure": {
        "header": {
          "description": "Header fixo no topo",
          "elements": [
            "Título: 'Planejamento de Treinos'",
            "Dropdown de equipe atual",
            "Botão '+ Novo Treino' com destaque visual",
            "Filtro rápido (por atleta ou período)"
          ]
        },
        "sidebar": {
          "description": "Sidebar esquerda fixa e colapsável integrada ao sistema",
          "behavior": "Expande submenu ao clicar em 'Treinos'",
          "activeState": "Item ativo com destaque visual (cor ou ícone)",
          "navigation": [
            {
              "icon": "📅",
              "label": "Agenda Semanal",
              "route": "/training/agenda",
              "isDefault": true
            },
            {
              "icon": "🗓️",
              "label": "Calendário Mensal",
              "route": "/training/calendario"
            },
            {
              "icon": "📊",
              "label": "Planejamento",
              "route": "/training/planejamento"
            },
            {
              "icon": "🏋️",
              "label": "Banco de Exercícios",
              "route": "/training/banco"
            },
            {
              "icon": "📈",
              "label": "Avaliações",
              "route": "/training/avaliacoes"
            }
          ]
        },
        "mainArea": {
          "description": "Área principal dinâmica à direita da sidebar",
          "behavior": "Conteúdo adaptativo por subrota sem recarregar página completa",
          "transitions": "Fade ou slide horizontal entre subrotas"
        }
      },

      "subroutes": {
        "agenda": {
          "route": "/training/agenda",
          "title": "Agenda Semanal",
          "layout": "Calendário horizontal (segunda a domingo)",
          "features": [
            "Cada bloco: sessão com cor por tipo",
            "Hover: resumo do treino (equipe, horário, local, foco)",
            "Modal ao clicar: detalhes completos + ações rápidas",
            "Arrastar sessões entre dias (drag & drop)",
            "Duplicar sessão",
            "Fechar sessão (bloqueia edição, gera estatística)",
            "Filtro por atleta, tipo de treino, foco"
          ],
          "interactions": {
            "dragAndDrop": {
              "description": "Arrastar sessões entre dias",
              "animation": "scale leve + sombra + snapping visual",
              "feedback": "Toast: 'Sessão movida para {dia}'"
            },
            "duplicate": {
              "description": "Duplicar sessão existente",
              "action": "Criar cópia com modal de confirmação"
            },
            "closeSession": {
              "description": "Fechar sessão para análise",
              "warning": "Ação irreversível, requer confirmação dupla",
              "result": "Gera estatística automaticamente"
            }
          },
          "animations": {
            "weekChange": "slide horizontal + fade",
            "cardAppear": "fade-in com leve delay em cascata",
            "tooltips": "fade-in suave com 200ms delay"
          },
          "modals": {
            "createEdit": {
              "title": "Criar/Editar Sessão",
              "animation": "fade + scale leve (pop-up)",
              "fields": [
                "Título",
                "Equipe",
                "Data e hora",
                "Tipo de treino",
                "Foco principal",
                "Exercícios",
                "Observações"
              ],
              "actions": ["Salvar", "Salvar e continuar", "Cancelar"]
            },
            "viewDetails": {
              "title": "Ver Detalhes de Sessão",
              "animation": "drawer lateral",
              "content": "Visualização somente leitura com botão de editar"
            }
          },
          "toasts": {
            "sessionCreated": "✅ Sessão adicionada ao dia X",
            "sessionEdited": "✏️ Sessão atualizada",
            "sessionDeleted": "🗑️ Sessão removida (com Desfazer 5s)",
            "sessionMoved": "🔄 Sessão movida para {dia}",
            "error": "❌ Algo deu errado. Tente novamente."
          },
          "emptyState": {
            "title": "Nenhum treino agendado esta semana",
            "description": "Crie seu primeiro treino para começar",
            "action": "Botão 'Criar Treino'"
          }
        },

        "calendario": {
          "route": "/training/calendario",
          "title": "Calendário Mensal",
          "layout": "Visualização Gantt-like por dia",
          "features": [
            "Destaque visual para eventos (treino, jogo, avaliação)",
            "Badges com ícones: 🏋️, ⚽, 📊, 🧘",
            "Hover com resumo e indicadores de carga",
            "Modal ao clicar em dia para adicionar/editar",
            "Sugestão automática de foco baseada no ciclo atual"
          ],
          "interactions": {
            "dayHover": "leve destaque com sombra ou borda",
            "dayClick": "Modal compacto com data pré-preenchida",
            "eventTypes": ["training", "game", "evaluation", "recovery"]
          },
          "animations": {
            "monthChange": "slide horizontal + fade",
            "eventAppear": "fade-in progressivo"
          },
          "modals": {
            "addEvent": {
              "title": "Adicionar Evento",
              "animation": "fade-in",
              "fields": ["Tipo de evento", "Horário", "Equipe", "Foco", "Observações"],
              "smartSuggestions": true
            }
          }
        },

        "planejamento": {
          "route": "/training/planejamento",
          "title": "Planejamento Estrutural",
          "layout": "Timeline ou cards colapsáveis com hierarquia",
          "hierarchy": ["Trimestre", "Mesociclo", "Microciclo"],
          "features": [
            "Visão interativa de 3 camadas (Trimestre → Meso → Micro)",
            "Microciclos dentro dos mesociclos",
            "Destaques com foco técnico (ícones ou cores)",
            "Alertas automáticos por desvios de foco",
            "Criar/editar/clonar ciclos",
            "Inserir treinos diretamente em ciclos",
            "Visualização de carga semanal",
            "Alertas de microciclos com foco repetido",
            "Alerta de ausência de treinos por X dias"
          ],
          "interactions": {
            "expandCollapse": "accordion vertical suave",
            "createCycle": "Drawer lateral para não sobrepor calendário",
            "cloneMicrocycle": "Duplicar com confirmação",
            "dragSessions": "Arrastar sessões para ciclos"
          },
          "animations": {
            "cycleSwitch": "slide horizontal com fade",
            "expandMeso": "accordion vertical suave",
            "modifiedHighlight": "pulsar discreto no contorno"
          },
          "modals": {
            "createEditMicrocycle": {
              "type": "drawer lateral",
              "fields": ["Nome", "Foco", "Período", "Sessões vinculadas"]
            },
            "evaluateMicrocycle": {
              "type": "modal",
              "fields": [
                "Slider de intensidade",
                "Foco mantido? (sim/não)",
                "Observações"
              ],
              "trigger": "Ao fechar microciclo"
            }
          },
          "alerts": {
            "focusDeviation": {
              "message": "⚠️ 3 microciclos seguidos fora do foco planejado",
              "style": "Toast amarelo com link 'ver detalhe'"
            },
            "noTraining": {
              "message": "Nenhum treino há {X} dias",
              "style": "Badge vermelho"
            }
          },
