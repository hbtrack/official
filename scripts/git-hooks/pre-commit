#!/usr/bin/env python3
"""
HB Track Pre-Commit Hook
Chama: scripts/run/hb_cli.py check --mode pre-commit
SSOT: docs/_canon/specs/Hb cli.md
Versão: v1.0.4
"""

import sys
import subprocess
from pathlib import Path

def main():
    # Determinar repo root (hook está em scripts/git-hooks/)
    hook_dir = Path(__file__).resolve().parent
    repo_root = hook_dir.parent.parent
    hb_script = repo_root / "scripts" / "run" / "hb_cli.py"
    
    if not hb_script.exists():
        print(f"❌ PRE-COMMIT HOOK: hb_cli.py not found at {hb_script}", file=sys.stderr)
        sys.exit(1)
    
    # Executar hb check
    result = subprocess.run(
        [sys.executable, str(hb_script), "check", "--mode", "pre-commit"],
        cwd=repo_root
    )
    
    # Propagar exit code
    sys.exit(result.returncode)

if __name__ == "__main__":
    main()
