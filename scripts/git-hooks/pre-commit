#!/usr/bin/env python3
"""
HB Track Pre-Commit Hook

Governança única: contract-driven (SSOT em `.contract_driven/*`).

Executa o pipeline oficial de contract gates e bloqueia commit quando houver
falhas bloqueantes.

SSOT de orquestração e semântica dos gates:
- `docs/_canon/CI_CONTRACT_GATES.md`
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def main() -> int:
    # Determinar repo root (hook está em scripts/git-hooks/)
    hook_dir = Path(__file__).resolve().parent
    repo_root = hook_dir.parent.parent

    validate = repo_root / "scripts" / "validate_contracts.py"
    if not validate.exists():
        print(f"❌ PRE-COMMIT HOOK: scripts/validate_contracts.py não encontrado em {validate}", file=sys.stderr)
        return 1

    result = subprocess.run([sys.executable, str(validate)], cwd=repo_root)
    return int(result.returncode)


if __name__ == "__main__":
    raise SystemExit(main())
