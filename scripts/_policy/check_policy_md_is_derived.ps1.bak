<# HB Track — check_policy_md_is_derived.ps1

Purpose:
  Deterministically verify that the derived Markdown matches the SSOT YAML.
  This is the "anti-drift" gate for: scripts/scripts_classification.md

Reads:
  - scripts/_policy/script_classification.yaml (SSOT)
  - scripts/_policy/scripts.policy.schema.json (schema)
  - scripts/scripts_classification.md (DERIVED)

Requires:
  - python available in PATH
  - render_policy_md.py available at scripts/_policy/render_policy_md.py
  - PyYAML + jsonschema installed in the active python environment

Deterministic exit codes:
  0 = PASS (MD matches SSOT rendering)
  2 = FAIL (drift detected OR SSOT invalid)
  3 = HARNESS ERROR (missing files / python runtime failure)

Notes:
  - This script does NOT modify repo files.
  - It renders to a temp file and compares exact bytes (normalized to LF). #>

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

function Write-Err([string]$msg) {
  Write-Host $msg -ForegroundColor Red
}

function Write-Ok([string]$msg) {
  Write-Host $msg -ForegroundColor Green
}

function Normalize-LF([string]$s) {
  return ($s -replace "`r`n", "`n") -replace "`r", "`n"
}

try {
  $repoRoot = (Resolve-Path ".").Path

  $ssot = Join-Path $repoRoot "scripts\_policy\script_classification.yaml"
  $schema = Join-Path $repoRoot "scripts\_policy\scripts.policy.schema.json"
  $renderer = Join-Path $repoRoot "scripts\_policy\render_policy_md.py"
  $derived = Join-Path $repoRoot "scripts\scripts_classification.md"

  foreach ($p in @($ssot, $schema, $renderer, $derived)) {
    if (-not (Test-Path -LiteralPath $p)) {
      Write-Err "[HARNESS_ERROR] Missing required file: $p"
      exit 3
    }
  }

  # Use a deterministic temp path
  $tmpDir = Join-Path $env:TEMP "hb_policy_md_check"
  New-Item -ItemType Directory -Force -Path $tmpDir | Out-Null
  $tmpOut = Join-Path $tmpDir "scripts_classification.rendered.md"

  # Render using SSOT (do not overwrite repo file)
  $py = "python"
  $args = @(
    $renderer,
    "--ssot", $ssot,
    "--schema", $schema,
    "--out", $tmpOut
  )

  $psi = New-Object System.Diagnostics.ProcessStartInfo
  $psi.FileName = $py
  $psi.Arguments = ($args | ForEach-Object {
      if ($_ -match '\s') { '"' + ($_ -replace '"','\"') + '"' } else { $_ }
    }) -join ' '
  $psi.UseShellExecute = $false
  $psi.RedirectStandardOutput = $true
  $psi.RedirectStandardError = $true
  $psi.CreateNoWindow = $true

  $proc = New-Object System.Diagnostics.Process
  $proc.StartInfo = $psi

  [void]$proc.Start()
  $stdout = $proc.StandardOutput.ReadToEnd()
  $stderr = $proc.StandardError.ReadToEnd()
  $proc.WaitForExit()

  $rc = $proc.ExitCode
  if ($rc -ne 0) {
    Write-Err "[FAIL] Renderer returned exit code $rc"
    if ($stdout) { Write-Host (Normalize-LF $stdout) }
    if ($stderr) { Write-Host (Normalize-LF $stderr) }
    if ($rc -eq 2) { exit 2 }
    exit 3
  }

  if (-not (Test-Path -LiteralPath $tmpOut)) {
    Write-Err "[HARNESS_ERROR] Renderer did not produce output file: $tmpOut"
    exit 3
  }

  # Compare content (normalized to LF)
  $repoText = Normalize-LF (Get-Content -LiteralPath $derived -Raw -Encoding UTF8)
  $tmpText  = Normalize-LF (Get-Content -LiteralPath $tmpOut  -Raw -Encoding UTF8)

  if ($repoText -ceq $tmpText) {
    Write-Ok "[PASS] scripts/scripts_classification.md matches SSOT rendering."
    exit 0
  }

  # If drift, provide a small, deterministic diff summary (first mismatch line)
  $repoLines = $repoText -split "`n"
  $tmpLines  = $tmpText  -split "`n"
  $max = [Math]::Min($repoLines.Count, $tmpLines.Count)
  $firstDiff = -1
  for ($i=0; $i -lt $max; $i++) {
    if (-not ($repoLines[$i] -ceq $tmpLines[$i])) { $firstDiff = $i; break }
  }
  if ($firstDiff -eq -1 -and $repoLines.Count -ne $tmpLines.Count) {
    $firstDiff = $max
  }

  Write-Err "[FAIL] Drift detected: derived Markdown does not match SSOT rendering."
  if ($firstDiff -ge 0) {
    $lineNo = $firstDiff + 1
    Write-Host ("First difference at line {0}:" -f $lineNo)
    Write-Host ("  repo: {0}" -f $repoLines[$firstDiff])
    Write-Host ("  ssot: {0}" -f $tmpLines[$firstDiff])
  }

  Write-Host ""
  Write-Host "Remediation:"
  Write-Host "  1) Edit SSOT: scripts/_policy/script_classification.yaml"
  Write-Host "  2) Re-render: python scripts/_policy/render_policy_md.py --out scripts/scripts_classification.md"
  Write-Host "  3) Re-run this check"

  exit 2
}
catch {
  Write-Err "[HARNESS_ERROR] $($_.Exception.GetType().Name): $($_.Exception.Message)"
  exit 3
}
