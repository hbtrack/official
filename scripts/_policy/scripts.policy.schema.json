{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scripts/_policy/scripts.policy.schema.json",
  "title": "HB Track Scripts Policy (SSOT) Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "norm",
    "taxonomy",
    "artifacts",
    "naming",
    "headers",
    "rules"
  ],
  "properties": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "date",
        "status",
        "scope_root",
        "derived_markdown",
        "schema"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": { "type": "string", "enum": ["APPROVED", "DRAFT", "DEPRECATED"] },
        "scope_root": { "type": "string", "const": "scripts" },
        "derived_markdown": { "type": "string", "pattern": "^scripts/[^\\s]+\\.md$" },
        "schema": { "type": "string", "const": "scripts/_policy/scripts.policy.schema.json" }
      }
    },

    "norm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bcp14", "rfc"],
      "properties": {
        "bcp14": { "type": "boolean", "const": true },
        "rfc": {
          "type": "array",
          "items": { "type": "string", "enum": ["RFC2119", "RFC8174"] },
          "minItems": 2,
          "uniqueItems": true
        }
      }
    },

    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories_order", "categories"],
      "properties": {
        "categories_order": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "reset",
              "migrate",
              "fixes",
              "seeds",
              "generate",
              "checks",
              "diagnostics",
              "ops",
              "run",
              "temp"
            ]
          }
        },
        "categories": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "checks",
            "diagnostics",
            "fixes",
            "generate",
            "migrate",
            "ops",
            "reset",
            "seeds",
            "run",
            "temp"
          ],
          "properties": {
            "checks": { "$ref": "#/$defs/category_checks" },
            "diagnostics": { "$ref": "#/$defs/category_diagnostics" },
            "fixes": { "$ref": "#/$defs/category_fixes" },
            "generate": { "$ref": "#/$defs/category_generate" },
            "migrate": { "$ref": "#/$defs/category_migrate" },
            "ops": { "$ref": "#/$defs/category_ops" },
            "reset": { "$ref": "#/$defs/category_reset" },
            "seeds": { "$ref": "#/$defs/category_seeds" },
            "run": { "$ref": "#/$defs/category_run" },
            "temp": { "$ref": "#/$defs/category_temp" }
          }
        }
      }
    },

    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "output_only", "must_be_gitignored", "allow_files", "forbidden_extensions"],
      "properties": {
        "path": { "type": "string", "const": "scripts/artifacts" },
        "output_only": { "type": "boolean", "const": true },
        "must_be_gitignored": { "type": "boolean", "const": true },
        "allow_files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "forbidden_extensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ext" }
        }
      }
    },

    "naming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_pattern",
        "forbidden_prefixes",
        "forbidden_generic_names",
        "must_match_folder_prefix",
        "scope_must_match_subscope_dir"
      ],
      "properties": {
        "canonical_pattern": { "type": "string", "minLength": 10 },
        "forbidden_prefixes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "forbidden_generic_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "must_match_folder_prefix": { "type": "boolean" },
        "scope_must_match_subscope_dir": { "type": "boolean" }
      }
    },

    "headers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for_extensions",
        "required_fields",
        "optional_fields",
        "enums",
        "missing_header_behavior"
      ],
      "properties": {
        "required_for_extensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ext" }
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "optional_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "enums": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "HB_SCRIPT_KIND",
            "HB_SCRIPT_SIDE_EFFECTS",
            "HB_SCRIPT_IDEMPOTENT",
            "HB_SCRIPT_RISK"
          ],
          "properties": {
            "HB_SCRIPT_KIND": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "CHECK",
                  "DIAGNOSTIC",
                  "FIX",
                  "GENERATE",
                  "MIGRATE",
                  "OPS",
                  "RESET",
                  "SEED",
                  "RUNNER",
                  "TEMP"
                ]
              }
            },
            "HB_SCRIPT_SIDE_EFFECTS": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/side_effect" }
            },
            "HB_SCRIPT_IDEMPOTENT": {
              "type": "array",
              "minItems": 2,
              "uniqueItems": true,
              "items": { "type": "string", "enum": ["YES", "NO"] }
            },
            "HB_SCRIPT_RISK": {
              "type": "array",
              "minItems": 3,
              "uniqueItems": true,
              "items": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] }
            }
          }
        },
        "missing_header_behavior": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default_kind", "gate_should_fail"],
          "properties": {
            "default_kind": { "type": "string", "enum": ["TEMP"] },
            "gate_should_fail": { "type": "boolean" }
          }
        }
      }
    },

    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbid_temp_referenced_by_run",
        "forbid_executable_in_artifacts",
        "forbid_fix_named_in_checks_or_diagnostics",
        "temp_only_tmp_prefix",
        "category_root_no_executables"
      ],
      "properties": {
        "forbid_temp_referenced_by_run": { "$ref": "#/$defs/rule_toggle" },
        "forbid_executable_in_artifacts": { "$ref": "#/$defs/rule_toggle" },
        "forbid_fix_named_in_checks_or_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "severity", "pattern"],
          "properties": {
            "enabled": { "type": "boolean" },
            "severity": { "$ref": "#/$defs/severity" },
            "pattern": { "type": "string", "minLength": 1 }
          }
        },
        "temp_only_tmp_prefix": { "$ref": "#/$defs/rule_toggle" },
        "category_root_no_executables": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "severity", "exceptions"],
          "properties": {
            "enabled": { "type": "boolean" },
            "severity": { "$ref": "#/$defs/severity" },
            "exceptions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "severity": { "type": "string", "enum": ["FAIL", "WARN"] },
    "rule_toggle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "severity"],
      "properties": {
        "enabled": { "type": "boolean" },
        "severity": { "$ref": "#/$defs/severity" }
      }
    },
    "ext": { "type": "string", "enum": [".py", ".ps1", ".sql"] },
    "side_effect": {
      "type": "string",
      "enum": ["NONE", "DB_READ", "DB_WRITE", "FS_READ", "FS_WRITE", "ENV_WRITE", "NET", "ANY"]
    },

    "category_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "prefix",
        "path",
        "requires_subscope",
        "subscope",
        "allowed_extensions",
        "allowed_side_effects",
        "forbidden_side_effects",
        "ci_eligible",
        "must_be_deterministic"
      ],
      "properties": {
        "kind": { "type": "string" },
        "prefix": { "type": "string", "minLength": 2 },
        "path": { "type": "string", "pattern": "^scripts\\/[a-z_\\/]+$" },
        "requires_subscope": { "type": "boolean" },
        "subscope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_extensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ext" }
        },
        "allowed_side_effects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/side_effect" }
        },
        "forbidden_side_effects": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/side_effect" }
        },
        "ci_eligible": { "type": "boolean" },
        "must_be_deterministic": { "type": "boolean" }
      }
    },

    "category_checks": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["exit_codes"],
          "properties": {
            "kind": { "const": "CHECK" },
            "path": { "const": "scripts/checks" },
            "prefix": { "const": "check_" },
            "exit_codes": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pass", "fail", "harness_error"],
              "properties": {
                "pass": { "type": "integer", "const": 0 },
                "fail": { "type": "integer", "const": 2 },
                "harness_error": { "type": "integer", "const": 3 }
              }
            }
          }
        }
      ]
    },

    "category_diagnostics": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "DIAGNOSTIC" },
            "path": { "const": "scripts/diagnostics" },
            "prefix": { "const": "diag_" }
          }
        }
      ]
    },

    "category_fixes": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifacts_required", "artifacts_root"],
          "properties": {
            "kind": { "const": "FIX" },
            "path": { "const": "scripts/fixes" },
            "prefix": { "const": "fix_" },
            "artifacts_required": { "type": "boolean" },
            "artifacts_root": { "type": "string", "const": "scripts/artifacts" }
          }
        }
      ]
    },

    "category_generate": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["idempotent_required"],
          "properties": {
            "kind": { "const": "GENERATE" },
            "path": { "const": "scripts/generate" },
            "prefix": { "const": "gen_" },
            "idempotent_required": { "type": "boolean" }
          }
        }
      ]
    },

    "category_migrate": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "MIGRATE" },
            "path": { "const": "scripts/migrate" },
            "prefix": { "const": "mig_" }
          }
        }
      ]
    },

    "category_ops": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["requires_flags"],
          "properties": {
            "kind": { "const": "OPS" },
            "path": { "const": "scripts/ops" },
            "prefix": { "const": "ops_" },
            "requires_flags": { "type": "boolean" }
          }
        }
      ]
    },

    "category_reset": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["confirmation_required", "must_print_banner"],
          "properties": {
            "kind": { "const": "RESET" },
            "path": { "const": "scripts/reset" },
            "prefix": { "const": "reset_" },
            "confirmation_required": { "type": "boolean" },
            "must_print_banner": { "type": "string", "minLength": 3 }
          }
        }
      ]
    },

    "category_seeds": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "SEED" },
            "path": { "const": "scripts/seeds" },
            "prefix": { "const": "seed_" }
          }
        }
      ]
    },

    "category_run": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["wrappers_only", "fs_write_restriction"],
          "properties": {
            "kind": { "const": "RUNNER" },
            "path": { "const": "scripts/run" },
            "prefix": { "const": "run_" },
            "wrappers_only": { "type": "boolean" },
            "fs_write_restriction": {
              "type": "object",
              "additionalProperties": false,
              "required": ["allowed_write_roots"],
              "properties": {
                "allowed_write_roots": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": { "type": "string", "pattern": "^scripts\\/[^\\s]+$" }
                }
              }
            }
          }
        }
      ]
    },

    "category_temp": {
      "allOf": [
        { "$ref": "#/$defs/category_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["must_be_gitignored", "promotion_threshold_uses"],
          "properties": {
            "kind": { "const": "TEMP" },
            "path": { "const": "scripts/temp" },
            "prefix": { "const": "tmp_" },
            "must_be_gitignored": { "type": "boolean" },
            "promotion_threshold_uses": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    }
  }
}

