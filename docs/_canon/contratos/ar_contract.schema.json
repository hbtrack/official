{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hbtrack:ar_contract.schema.json",
  "schema_version": "1.2.0",
  "title": "HB Track AR Contract (Plan JSON) â schema v1.2.0",
  "description": "Contract schema for AR plans. Evidence path must be deterministic: docs/hbtrack/evidence/AR_<id>/executor_main.log",
  "type": "object",
  "required": ["project", "version", "tasks"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "const": "HB Track"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "MUST igualar o 'schema_version' declarado neste ar_contract.schema.json (ex.: 1.2.0). NĂO ĂŠ a versĂŁo do protocolo do hb_cli."
    },

    "notes": {
      "type": "string",
      "maxLength": 5000,
      "description": "Notas gerais do Arquiteto sobre o plano (texto livre canĂ´nico)."
    },
    "assumptions": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 },
      "description": "SuposiĂ§Ăľes feitas ao gerar o plano."
    },

    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "criteria", "validation_command"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{3}$",
            "description": "ID no formato 001..999. MUST ser Ăşnico dentro do plano."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "minLength": 20,
            "maxLength": 20000
          },
          "criteria": {
            "type": "string",
            "minLength": 10,
            "maxLength": 5000
          },

          "gate": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "RĂłtulo do gate (informativo)."
          },

          "validation_command": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "description": "Comando exato para hb report (contrato forte)."
          },

          "evidence_file": {
            "type": "string",
            "pattern": "^docs/hbtrack/evidence/AR_[0-9]{3}/executor_main\\.log$",
            "description": "DERIVED/DETERMINĂSTICO. Se presente, MUST ser exatamente o path canĂ´nico do evidence pack do Executor. O Arquiteto NĂO escolhe paths arbitrĂĄrios."
          },

          "write_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 5,
              "maxLength": 200,
              "pattern": "^[A-Za-z0-9_/. \\*\\-]+$"
            },
            "minItems": 0,
            "maxItems": 10,
            "uniqueItems": true,
            "description": "Paths de arquivos/diretĂłrios que esta task pode modificar. MUST ser explĂ­cito para tasks que tocam cĂłdigo (governed roots). MAY ser vazio para tasks doc-only. Aceita wildcards (*)."
          },

          "ssot_touches": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 3,
            "items": {
              "type": "string",
              "enum": [
                "docs/ssot/schema.sql",
                "docs/ssot/openapi.json",
                "docs/ssot/alembic_state.txt"
              ]
            },
            "description": "SSOTs que esta task pode tocar (opcional)."
          },

          "rollback_plan": {
            "type": "string",
            "minLength": 20,
            "maxLength": 4000,
            "pattern": "^(?:python\\s+scripts/run/hb_cli\\.py[^\\n]*|git\\s+checkout\\s+--\\s+[^.\\n][^\\n]*|git\\s+clean\\s+-fd\\s+[^.\\n][^\\n]*|psql\\s+-c\\s+\\\"TRUNCATE[^\\\"]*\\\")(?:\\n(?:python\\s+scripts/run/hb_cli\\.py[^\\n]*|git\\s+checkout\\s+--\\s+[^.\\n][^\\n]*|git\\s+clean\\s+-fd\\s+[^.\\n][^\\n]*|psql\\s+-c\\s+\\\"TRUNCATE[^\\\"]*\\\"))*$",
            "description": "OBRIGATĂRIO para tasks que tocam banco (schema.sql ou alembic_state.txt). Whitelist estrita (linha a linha): (1) python scripts/run/hb_cli.py ... (2) git checkout -- <file> (3) git clean -fd <dir> (4) psql -c \"TRUNCATE...\" (somente staging/test). Path traversal bloqueado (nĂŁo pode comeĂ§ar com .)."
          },

          "notes": {
            "type": "string",
            "maxLength": 5000,
            "description": "Notas especĂ­ficas da task (texto livre canĂ´nico)."
          },
          "risks": {
            "type": "array",
            "maxItems": 20,
            "items": { "type": "string", "minLength": 1, "maxLength": 500 },
            "description": "Riscos/atenĂ§Ăľes para o Executor."
          },

          "retry_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 99,
            "default": 0,
            "description": "NĂşmero de tentativas do ciclo (gate retry_limit)."
          },

          "status": {
            "type": "string",
            "enum": [
              "PENDENTE",
              "EM_EXECUCAO",
              "SUCESSO",
              "REJEITADO",
              "BLOQUEADO_INFRA",
              "NEEDS_REVIEW",
              "VERIFICADO",
              "FALHA",
              "SUPERSEDED"
            ],
            "description": "DEPRECATED (drift-risk). Status canĂ´nico ĂŠ derivado da AR + hb verify + hb seal. Se usado, MUST refletir o estado real, ou hb_cli MAY rejeitar em gates futuros."
          },

          "last_test_feedback": {
            "type": "string",
            "maxLength": 2000,
            "description": "DEPRECATED (drift-risk). Feedback canĂ´nico do Testador deve viver no TESTADOR_REPORT + carimbo na AR."
          },

          "execution_evidence": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "local_run_success": { "type": "boolean" },
              "timestamp": { "type": "string", "format": "date-time" }
            },
            "required": ["local_run_success"],
            "description": "DEPRECATED (drift-risk). EvidĂŞncia canĂ´nica ĂŠ o evidence pack do Executor + TESTADOR_REPORT."
          }
        },

        "if": {
          "properties": {
            "ssot_touches": {
              "contains": {
                "enum": ["docs/ssot/schema.sql", "docs/ssot/alembic_state.txt"]
              }
            }
          },
          "required": ["ssot_touches"]
        },
        "then": {
          "required": ["id", "title", "description", "criteria", "validation_command", "rollback_plan"]
        }
      }
    }
  }
}