  "description": "Plano de dados do módulo de Scout (Scouting de Partidas). Derivado do schema.sql canônico. Define entidades, catálogos lookup, regras de registro de eventos e restrições de negócio.",

  "entities": {
    "matches": {
      "table": "matches",
      "purpose": "Jogo oficial. Ponto de entrada para roster, eventos, estatísticas.",
      "key_fields": {
        "id": "uuid PK",
        "season_id": "uuid FK → seasons",
        "competition_id": "uuid FK → competitions (nullable)",
        "match_date": "date NOT NULL",
        "start_time": "time nullable",
        "venue": "varchar(120) nullable",
        "phase": "enum: group | semifinal | final | friendly",
        "status": "enum: scheduled | in_progress | finished | cancelled",
        "home_team_id": "uuid FK → teams",
        "away_team_id": "uuid FK → teams",
        "our_team_id": "uuid FK → teams (MUST equal home ou away)",
        "final_score_home": "smallint nullable",
        "final_score_away": "smallint nullable"
      },
      "constraints": [
        "home_team_id <> away_team_id",
        "our_team_id IN (home_team_id, away_team_id)",
        "final_score_home/away >= 0 quando NOT NULL",
        "soft_delete: deleted_at + deleted_reason obrigatórios juntos"
      ]
    },

    "match_teams": {
      "table": "match_teams",
      "purpose": "Bridge match ↔ teams. Identifica papel de cada equipe no jogo.",
      "key_fields": {
        "id": "uuid PK",
        "match_id": "uuid FK → matches",
        "team_id": "uuid FK → teams",
        "is_home": "boolean",
        "is_our_team": "boolean"
      }
    },

    "match_roster": {
      "table": "match_roster",
      "purpose": "Súmula oficial. Define atletas elegíveis para o jogo.",
      "key_fields": {
        "id": "uuid PK",
        "match_id": "uuid FK → matches",
        "team_id": "uuid FK → teams",
        "athlete_id": "uuid FK → athletes",
        "jersey_number": "smallint > 0",
        "is_starting": "boolean nullable",
        "is_goalkeeper": "boolean NOT NULL",
        "is_available": "boolean NOT NULL",
        "notes": "text nullable"
      },
      "notes": "Somente atletas presentes nesta tabela podem ser referenciados em match_events.athlete_id (regra RD4)."
    },

    "match_periods": {
      "table": "match_periods",
      "purpose": "Estrutura de tempo do jogo.",
      "key_fields": {
        "id": "uuid PK",
        "match_id": "uuid FK → matches",
        "number": "smallint >= 1",
        "duration_seconds": "integer > 0",
        "period_type": "enum: regular | extra_time | shootout_7m"
      }
    },

    "match_possessions": {
      "table": "match_possessions",
      "purpose": "Sequências de posse de bola para análise tática de eficiência.",
      "key_fields": {
        "id": "uuid PK",
        "match_id": "uuid FK → matches",
        "team_id": "uuid FK → teams",
        "start_period_number": "smallint >= 1",
        "start_time_seconds": "integer >= 0",
        "end_period_number": "smallint >= start_period_number",
        "end_time_seconds": "integer >= 0",
        "start_score_our": "smallint",
        "start_score_opponent": "smallint",
        "end_score_our": "smallint",
        "end_score_opponent": "smallint",
        "result": "enum: goal | turnover | seven_meter_won | time_over"
      }
    },

    "match_events": {
      "table": "match_events",
      "purpose": "Eventos de jogo lance a lance. Coração analítico: reconstrói jogo, contexto tático e gera estatísticas.",
      "key_fields": {
        "id": "uuid PK",
        "match_id": "uuid FK → matches ON DELETE CASCADE",
        "team_id": "uuid FK → teams (time que executou o evento)",
        "opponent_team_id": "uuid FK → teams nullable",
        "athlete_id": "uuid FK → athletes nullable (executora do evento)",
        "assisting_athlete_id": "uuid FK → athletes nullable (assistência)",
        "secondary_athlete_id": "uuid FK → athletes nullable (uso contextual)",
        "period_number": "smallint >= 1",
        "game_time_seconds": "integer >= 0",
        "phase_of_play": "varchar(32) FK → phases_of_play.code",
        "possession_id": "uuid FK → match_possessions nullable ON DELETE SET NULL",
        "advantage_state": "varchar(32) FK → advantage_states.code",
        "score_our": "smallint >= 0 (placar do nosso time NO MOMENTO do evento)",
        "score_opponent": "smallint >= 0 (placar adversário NO MOMENTO do evento)",
        "event_type": "varchar(64) FK → event_types.code",
        "event_subtype": "varchar(64) FK → event_subtypes.code nullable",
        "outcome": "varchar(64) NOT NULL (resultado do evento, ex: goal/saved/missed/blocked/post)",
        "is_shot": "boolean (desnormalizado de event_types.is_shot)",
        "is_goal": "boolean (true quando o evento resultou em gol)",
        "x_coord": "numeric(5,2) 0–100 nullable (posição em quadra %)",
        "y_coord": "numeric(5,2) 0–100 nullable (posição em quadra %)",
        "related_event_id": "uuid FK → match_events nullable ON DELETE SET NULL (auto-referência)",
        "source": "enum: live | video | post_game_correction",
        "notes": "text nullable",
        "created_at": "timestamptz DEFAULT now()",
        "created_by_user_id": "uuid FK → users"
      },
      "indexes": [
        "ix_match_events_match_id",
        "ix_match_events_athlete_id",
        "ix_match_events_event_type",
        "ix_match_events_team_id",
        "ix_match_events_phase_of_play"
      ]
    }
  },

