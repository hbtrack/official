{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HB Track Command Specification Schema",
  "type": "object",
  "required": [
    "module",
    "version",
    "commands"
  ],
  "properties": {
    "module": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "trigger",
          "description",
          "payload"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "auth_required": {
            "type": "boolean",
            "default": true
          },
          "roles_allowed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}