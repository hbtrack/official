{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HB Track Projection Specification Schema",
  "type": "object",
  "required": ["module", "version", "status", "projections"],
  "properties": {
    "module": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "type": "string", "enum": ["draft_normativo", "normativo", "deprecated"] },
    "projections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name", 
          "description", 
          "source_events", 
          "grain", 
          "fields", 
          "refresh_mode", 
          "consistency_model", 
          "storage_target", 
          "rebuild_strategy", 
          "consumers"
        ],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "source_events": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "grain": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "refresh_mode": { "type": "string", "enum": ["sync", "async", "batch"] },
          "consistency_model": { "type": "string", "enum": ["strong", "eventual"] },
          "storage_target": { "type": "string", "enum": ["table", "materialized_view", "cache", "search_index"] },
          "rebuild_strategy": {
            "type": "object",
            "required": ["full_rebuild", "incremental"],
            "properties": {
              "full_rebuild": { "type": "boolean" },
              "incremental": { "type": "boolean" }
            }
          },
          "consumers": {
            "type": "object",
            "properties": {
              "endpoints": { "type": "array", "items": { "type": "string" } },
              "screens": { "type": "array", "items": { "type": "string" } },
              "analytics": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}