{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "approved_commands_registry.schema.json",
  "title": "Approved Commands Registry Schema",
  "description": "JSON Schema for docs/_ai/_specs/approved_commands_registry.yaml — SSOT for command whitelist/blacklist for AI agents in HB Track.",
  "type": "object",
  "required": ["version", "global_rules", "categories", "blacklist", "protected_files", "approval_protocol"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version of this registry."
    },
    "global_rules": {
      "type": "object",
      "description": "Normative global rules that agents MUST comply with.",
      "additionalProperties": {
        "$ref": "#/$defs/GlobalRule"
      }
    },
    "cwd_definitions": {
      "type": "object",
      "description": "CWD definitions used by commands.",
      "additionalProperties": {
        "$ref": "#/$defs/CwdDefinition"
      }
    },
    "categories": {
      "type": "object",
      "description": "Approved command categories.",
      "additionalProperties": {
        "$ref": "#/$defs/Category"
      }
    },
    "blacklist": {
      "type": "object",
      "description": "Prohibited command categories.",
      "additionalProperties": {
        "$ref": "#/$defs/BlacklistCategory"
      }
    },
    "protected_files": {
      "type": "object",
      "description": "Protected file categories guarded by baseline.",
      "additionalProperties": {
        "$ref": "#/$defs/ProtectedFileCategory"
      }
    },
    "approval_protocol": {
      "$ref": "#/$defs/ApprovalProtocol"
    },
    "cross_references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CrossReference"
      }
    },
    "workflows": {
      "type": "object",
      "description": "Reference workflows combining commands.",
      "additionalProperties": {
        "$ref": "#/$defs/Workflow"
      }
    }
  },
  "$defs": {

    "GlobalRule": {
      "type": "object",
      "required": ["id", "normative"],
      "properties": {
        "id": { "type": "string", "pattern": "^RULE-\\d+$" },
        "normative": { "type": "string", "description": "BCP 14 normative statement." }
      }
    },

    "CwdDefinition": {
      "type": "object",
      "required": ["path", "alias"],
      "properties": {
        "path": { "type": "string" },
        "alias": { "type": "string" },
        "validation": { "type": "string" }
      }
    },

    "Category": {
      "type": "object",
      "required": ["id", "label", "approval", "commands"],
      "properties": {
        "id": { "type": "string", "pattern": "^CAT-\\d+$" },
        "label": { "type": "string" },
        "approval": {
          "type": "string",
          "enum": ["automatic", "required", "gated", "mixed"]
        },
        "risk_level": {
          "type": "string",
          "enum": ["green", "yellow", "red", "critical"]
        },
        "description": { "type": "string" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" },
          "minItems": 1
        }
      }
    },

    "Command": {
      "type": "object",
      "required": ["id", "name", "syntax", "exit_codes", "approval"],
      "properties": {
        "id": { "type": "string", "pattern": "^CMD-\\d+\\.\\d+$" },
        "name": { "type": "string" },
        "syntax": { "type": "string" },
        "script_path": {
          "type": "string",
          "description": "Relative path to the script from repo root."
        },
        "description": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/Parameter" }
        },
        "exit_codes": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1
        },
        "exit_code_map": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Human-readable meaning of each exit code."
        },
        "cwd": {
          "type": "string",
          "description": "CWD alias (references cwd_definitions key)."
        },
        "approval": {
          "type": "string",
          "enum": ["automatic", "required", "gated"]
        },
        "risk_level": {
          "type": "string",
          "enum": ["green", "yellow", "red", "critical"]
        },
        "time_estimate": { "type": "string" },
        "normative": { "type": "string" },
        "commit_types": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "violation_types": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "structural_diff_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/DiffType" }
        },
        "field_diff_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/DiffType" }
        },
        "artifacts_generated": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_flags": { "type": "string" },
        "deprecated": { "type": "boolean" },
        "deprecated_reason": { "type": "string" }
      }
    },

    "Parameter": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "default": { "type": "string" },
        "deprecated": { "type": "boolean" },
        "dangerous": { "type": "boolean" }
      }
    },

    "DiffType": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": { "type": "string" }
    },

    "BlacklistCategory": {
      "type": "object",
      "required": ["id", "label", "normative", "commands"],
      "properties": {
        "id": { "type": "string", "pattern": "^BLACKLIST-[A-Z]$" },
        "label": { "type": "string" },
        "normative": { "type": "string" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/BlacklistedCommand" },
          "minItems": 1
        }
      }
    },

    "BlacklistedCommand": {
      "type": "object",
      "required": ["command", "reason"],
      "properties": {
        "command": { "type": "string" },
        "reason": { "type": "string" },
        "alternative": { "type": "string" }
      }
    },

    "ProtectedFileCategory": {
      "type": "object",
      "required": ["id", "label", "normative", "files"],
      "properties": {
        "id": { "type": "string", "pattern": "^PROTECTED-\\d+$" },
        "label": { "type": "string" },
        "normative": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },

    "ApprovalProtocol": {
      "type": "object",
      "required": ["normative", "options", "risk_classification"],
      "properties": {
        "normative": { "type": "string" },
        "options": {
          "type": "object",
          "required": ["Y", "N", "A"],
          "properties": {
            "Y": { "type": "string" },
            "N": { "type": "string" },
            "A": { "type": "string" }
          }
        },
        "risk_classification": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/RiskLevel"
          }
        }
      }
    },

    "RiskLevel": {
      "type": "object",
      "required": ["criteria", "action"],
      "properties": {
        "criteria": { "type": "string" },
        "action": { "type": "string" }
      }
    },

    "CrossReference": {
      "type": "object",
      "required": ["path", "relation"],
      "properties": {
        "path": { "type": "string" },
        "relation": { "type": "string" }
      }
    },

    "Workflow": {
      "type": "object",
      "required": ["label", "steps"],
      "properties": {
        "label": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/WorkflowStep" },
          "minItems": 1
        }
      }
    },

    "WorkflowStep": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "cmd_ref": {
          "type": "string",
          "pattern": "^CMD-\\d+\\.\\d+$",
          "description": "Reference to command ID."
        },
        "action": { "type": "string" }
      }
    }
  }
}
