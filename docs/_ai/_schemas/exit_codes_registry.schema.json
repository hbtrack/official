{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "exit_codes_registry.schema.json",
  "title": "HB Track Exit Codes Registry",
  "description": "JSON Schema for docs/_ai/_specs/exit_codes_registry.yaml — the SSOT for all exit codes in HB Track scripts.",
  "type": "object",
  "required": ["version", "exit_codes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version of the registry."
    },
    "exit_codes": {
      "type": "object",
      "description": "Map of exit code (string) to its definition.",
      "patternProperties": {
        "^\\d+$": { "$ref": "#/$defs/ExitCodeEntry" }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "special_codes": {
      "type": "object",
      "description": "OS/runtime signal codes (not script exit codes).",
      "patternProperties": {
        "^-?\\d+$": { "$ref": "#/$defs/SpecialCodeEntry" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "ExitCodeEntry": {
      "type": "object",
      "required": ["title", "severity", "normative", "description", "emitters"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Short human-readable title."
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error", "fatal"],
          "description": "Severity level for agent/human triage."
        },
        "normative": {
          "type": "string",
          "minLength": 10,
          "description": "BCP 14 (RFC 2119) normative statement using MUST/SHOULD/MAY."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description (may be in Portuguese)."
        },
        "emitters": {
          "type": "array",
          "items": { "$ref": "#/$defs/Emitter" },
          "minItems": 1,
          "description": "Scripts that return this exit code, with context."
        },
        "symptoms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Observable signs in script output."
        },
        "causes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Root causes that produce this exit code."
        },
        "troubleshooting": {
          "type": "array",
          "items": { "$ref": "#/$defs/TroubleshootingStep" },
          "description": "Ordered deterministic fix steps."
        }
      }
    },
    "SpecialCodeEntry": {
      "type": "object",
      "required": ["title", "severity", "normative", "description"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["info", "warning", "error", "fatal"] },
        "normative": { "type": "string", "minLength": 10 },
        "description": { "type": "string" },
        "causes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "troubleshooting": {
          "type": "array",
          "items": { "$ref": "#/$defs/TroubleshootingStep" }
        }
      }
    },
    "Emitter": {
      "type": "object",
      "required": ["path", "context"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^scripts/",
          "description": "Relative path from repo root to the emitter script."
        },
        "context": {
          "type": "string",
          "description": "When/why this script returns this code."
        }
      }
    },
    "TroubleshootingStep": {
      "type": "object",
      "required": ["step", "command"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "description": "Human-readable step description."
        },
        "command": {
          "type": "string",
          "description": "PowerShell/Python command to execute for this step."
        }
      }
    }
  }
}
