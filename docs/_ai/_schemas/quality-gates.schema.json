{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quality Gates Specification",
  "description": "JSON Schema que valida quality-gates.yml. Garante que thresholds e actions são válidos.",
  "type": "object",
  "required": ["version", "gates"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "gates": {
      "type": "object",
      "properties": {
        "loc_max": {
          "type": "integer",
          "minimum": 0
        },
        "complexity_max": {
          "type": "number",
          "minimum": 0
        },
        "coverage_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  }
}
