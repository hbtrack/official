{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HB Track Agent Specification",
  "description": "JSON Schema que valida agent-spec.json. Garante contract correto de agentes AI, evita bugs de especificação.",
  "type": "object",
  "required": ["version", "agent", "specifications"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "agent": {
      "type": "object",
      "required": ["name", "role", "scope"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "scope": { 
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "specifications": {
      "type": "object",
      "properties": {
        "rules": { "type": "array" },
        "constraints": { "type": "array" },
        "workflows": { "type": "array" }
      }
    }
  }
}
