<?xml version="1.0" encoding="UTF-8"?>
<specification>
  <metadata>
    <name>SPEC_AGENT_GUARDRAILS</name>
    <description>Guardrails de segurança e validade: o que nunca fazer, e como proteger o agente contra states inválidos.</description>
    <version>1.0</version>
  </metadata>

  <guardrails>
    <guardrail id="GR_001">
      <category>Environment</category>
      <rule>PowerShell must be 5.1</rule>
      <severity>CRITICAL</severity>
      <action>Abort if $PSVersionTable.PSVersion.Major -ne 5</action>
    </guardrail>

    <guardrail id="GR_002">
      <category>Environment</category>
      <rule>Python must be 3.11+</rule>
      <severity>CRITICAL</severity>
      <action>Abort if python --version reports &lt; 3.11</action>
    </guardrail>

    <guardrail id="GR_003">
      <category>Repository</category>
      <rule>Never execute gates with dirty working tree</rule>
      <severity>BLOCKING</severity>
      <action>Check git status --porcelain before any write operation</action>
    </guardrail>

    <guardrail id="GR_004">
      <category>Baseline</category>
      <rule>Baseline is LOCAL, never committed</rule>
      <severity>CRITICAL</severity>
      <action>Confirm .hb_guard/ in .gitignore; never git add baseline</action>
    </guardrail>

    <guardrail id="GR_005">
      <category>Models</category>
      <rule>Never edit inside HB-AUTOGEN regions</rule>
      <severity>BLOCKING</severity>
      <action>Grep for HB-AUTOGEN:BEGIN/END before edits</action>
    </guardrail>

    <guardrail id="GR_006">
      <category>Documentation</category>
      <rule>No temporary files in repository</rule>
      <severity>MAJOR</severity>
      <action>Use $env:TEMP for scratch files; never commit temp/backup</action>
    </guardrail>
  </guardrails>

  <TODO>
    <item>Adicionar recovery actions para cada guardrail violado</item>
    <item>Criar violation logger + alerting</item>
    <item>Documentar override policy (quando pode quebrar guardrail)</item>
  </TODO>
</specification>
