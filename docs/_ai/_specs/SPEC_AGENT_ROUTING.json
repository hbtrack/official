{
  "description": "Especificação de roteamento: quando usar qual agente/script, em que sequência, com que argumentos.",
  "version": "1.0",
  "routing_table": {
    "code_review": {
      "agent": "Agent with prompts/code_review.prompt.md",
      "applicable_to": ["Python files", "TypeScript files", "SQL migrations"],
      "entry_point": "Analyze file + provide suggestions",
      "output_format": "§1-§6 structured review with severity/evidence/solution"
    },
    "models_pipeline": {
      "agent": "Senior Dev (desenvolvedor.prompt.md)",
      "applicable_to": ["SQLAlchemy models", "Database schema", "Alembic migrations"],
      "entry_point": "Determine target table + exit code",
      "sequence": ["guard → parity → requirements"],
      "gates": {
        "guard": "models_autogen_gate.ps1 -Table <T> -Profile <P>",
        "parity": "parity_gate.ps1 -Table <T>",
        "requirements": "model_requirements.py --table <T> --profile <P>"
      }
    },
    "documentation_updates": {
      "agent": "Documentation Specialist",
      "applicable_to": ["Canon docs", "ADRs", "Changelog", "Guides"],
      "entry_point": "Identify doc + required changes",
      "approval": "Required before commit"
    },
    "git_operations": {
      "agent": "Senior Dev with git.prompt.md",
      "applicable_to": ["Commits", "PRs", "Merges"],
      "entry_point": "Review diff + get user approval",
      "constraints": "Never force-push, never auto-merge"
    }
  },
  "TODO": [
    "Criar decision tree para routing",
    "Documentar dependencies entre agentes",
    "Adicionar handoff protocol (quando passar para outro agente)",
    "Especificar approval workflow para cada routing"
  ]
}
