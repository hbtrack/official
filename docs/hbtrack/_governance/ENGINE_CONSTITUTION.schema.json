{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/hbtrack/_governance/ENGINE_CONSTITUTION.schema.json",
  "title": "ENGINE_CONSTITUTION",
  "description": "JSON Schema Draft-07 for HB Track Engine Constitution v2 sovereign governance document.",
  "type": "object",
  "required": [
    "meta",
    "exit_codes",
    "execution_phases",
    "status_vocabulary",
    "skip_policy",
    "aggregation_policy",
    "merge_policy",
    "waiver_policy",
    "global_type_system",
    "rule_sets"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "schema_ref",
        "version",
        "authority",
        "fail_closed",
        "execution_mode",
        "status"
      ],
      "additionalProperties": true,
      "properties": {
        "schema_ref": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "authority": {
          "type": "string",
          "enum": [
            "sovereign"
          ]
        },
        "fail_closed": {
          "type": "boolean"
        },
        "execution_mode": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "migrated_from": {
          "type": "string"
        },
        "migration_date": {
          "type": "string"
        }
      }
    },
    "exit_codes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "execution_phases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "status_vocabulary": {
      "type": "object",
      "required": [
        "values"
      ],
      "properties": {
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "skip_policy": {
      "type": "object",
      "required": [
        "missing_checker_impl"
      ],
      "properties": {
        "missing_checker_impl": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "aggregation_policy": {
      "type": "object",
      "required": [
        "fail_closed"
      ],
      "properties": {
        "fail_closed": {
          "type": "boolean"
        },
        "any_fail_triggers_overall_fail": {
          "type": "boolean"
        },
        "statuses_that_trigger_fail": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "merge_policy": {
      "type": "object",
      "required": [
        "sovereign_fields",
        "module_cannot_redefine_sovereign_fields"
      ],
      "properties": {
        "sovereign_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "module_cannot_redefine_sovereign_fields": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "waiver_policy": {
      "type": "object",
      "required": [
        "cannot_waive"
      ],
      "properties": {
        "waivers_allowed": {
          "type": "boolean"
        },
        "waiver_file": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cannot_waive": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "global_type_system": {
      "type": "object",
      "required": [
        "canonical_scalar_mappings",
        "polymorphic_discrimination_defaults"
      ],
      "properties": {
        "canonical_scalar_mappings": {
          "type": "array"
        },
        "polymorphic_discrimination_defaults": {
          "type": "object"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "rule_sets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "rule_id",
            "execution_phase",
            "checker_id"
          ],
          "properties": {
            "rule_id": {
              "type": "string"
            },
            "severity": {
              "type": "string"
            },
            "execution_phase": {
              "type": "string",
              "enum": [
                "PRE_PLAN",
                "POST_PLAN",
                "POST_EXECUTION"
              ]
            },
            "checker_id": {
              "type": "string"
            },
            "assertion": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}