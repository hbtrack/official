{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hbtrack:schema:cross-linter-rules:1.2.3:strict",
  "title": "HB Track Cross Linter Rules - Strict Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "scope",
    "global_type_system",
    "document_shape_rules",
    "cross_rules",
    "event_rules",
    "projection_rules",
    "side_effect_rules",
    "concurrency_rules",
    "ui_state_rules",
    "time_determinism_rules",
    "test_scenario_rules",
    "stub_anchor_rules",
    "handoff_rules",
    "restriction_prompt_rules",
    "diff_validation_rules",
    "waiver_policy",
    "outputs"
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "ruleId": {
      "type": "string",
      "pattern": "^[A-Z]+(?:-[A-Z]+)?-\\d{3}$"
    },
    "checkerId": {
      "type": "string",
      "pattern": "^check_[a-z0-9_]+$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "info"
      ]
    },
    "ruleObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "severity",
        "checker_id",
        "assertion"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/ruleId"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "checker_id": {
          "$ref": "#/$defs/checkerId"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          ]
        },
        "assertion": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "failure_message": {
          "type": "string"
        },
        "applies_to": {
          "type": "string"
        },
        "required_values": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "openapiScalar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "string",
            "integer",
            "boolean",
            "number"
          ]
        },
        "format": {
          "type": "string"
        }
      }
    },
    "scalarMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_type",
        "openapi",
        "backend_python",
        "frontend_typescript",
        "db_sql",
        "serialization"
      ],
      "properties": {
        "contract_type": {
          "type": "string",
          "enum": [
            "uuid",
            "date",
            "date-time",
            "integer",
            "boolean",
            "decimal"
          ]
        },
        "openapi": {
          "$ref": "#/$defs/openapiScalar"
        },
        "backend_python": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "frontend_typescript": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "frontend_constraint": {
          "type": "string"
        },
        "frontend_transport_number_forbidden": {
          "type": "boolean"
        },
        "db_sql": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "serialization": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "exitCodes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "0",
        "2",
        "3",
        "4"
      ],
      "properties": {
        "0": {
          "const": "PASS"
        },
        "2": {
          "const": "FAIL_ACTIONABLE"
        },
        "3": {
          "const": "ERROR_INFRA"
        },
        "4": {
          "const": "BLOCKED_INPUT"
        }
      }
    },
    "blockingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error",
        "warning",
        "info"
      ],
      "properties": {
        "error": {
          "type": "string",
          "enum": [
            "block"
          ]
        },
        "warning": {
          "type": "string",
          "enum": [
            "allow_with_waiver",
            "block",
            "allow"
          ]
        },
        "info": {
          "type": "string",
          "enum": [
            "allow",
            "allow_with_waiver",
            "block"
          ]
        }
      }
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "version",
        "status",
        "authority_level",
        "description",
        "fail_closed",
        "owner",
        "execution_mode",
        "exit_codes"
      ],
      "properties": {
        "document_id": {
          "const": "CROSS-LINTER-HBTRACK"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "DRAFT",
            "FINAL_DRAFT",
            "APPROVED"
          ]
        },
        "authority_level": {
          "type": "string",
          "enum": [
            "GLOBAL_SSOT"
          ]
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "fail_closed": {
          "type": "boolean",
          "const": true
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "deterministic_only"
          ]
        },
        "exit_codes": {
          "$ref": "#/$defs/exitCodes"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_documents",
        "generated_documents",
        "optional_documents",
        "module_pack_root_pattern"
      ],
      "properties": {
        "required_documents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "allOf": [
            {
              "contains": {
                "const": "00_ATLETAS_CROSS_LINTER_RULES.json"
              }
            },
            {
              "contains": {
                "const": "01_ATLETAS_OPENAPI.yaml"
              }
            },
            {
              "contains": {
                "const": "05_ATLETAS_EVENTS.asyncapi.yaml"
              }
            },
            {
              "contains": {
                "const": "08_ATLETAS_TRACEABILITY.yaml"
              }
            },
            {
              "contains": {
                "const": "12_ATLETAS_EXECUTION_BINDINGS.yaml"
              }
            },
            {
              "contains": {
                "const": "13_ATLETAS_DB_CONTRACT.yaml"
              }
            },
            {
              "contains": {
                "const": "14_ATLETAS_UI_CONTRACT.yaml"
              }
            },
            {
              "contains": {
                "const": "15_ATLETAS_INVARIANTS.yaml"
              }
            },
            {
              "contains": {
                "const": "17_ATLETAS_PROJECTIONS.yaml"
              }
            },
            {
              "contains": {
                "const": "18_ATLETAS_SIDE_EFFECTS.yaml"
              }
            },
            {
              "contains": {
                "const": "19_ATLETAS_TEST_SCENARIOS.yaml"
              }
            },
            {
              "contains": {
                "const": "20_ATLETAS_EXECUTOR_RESTRICTION_PROMPT.md"
              }
            }
          ]
        },
        "generated_documents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "allOf": [
            {
              "contains": {
                "const": "16_ATLETAS_AGENT_HANDOFF.json"
              }
            },
            {
              "contains": {
                "const": "anchor_manifest.json"
              }
            }
          ]
        },
        "optional_documents": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "module_pack_root_pattern": {
          "const": "docs/hbtrack/modules/<MODULE>/"
        }
      }
    },
    "global_type_system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_scalar_mappings",
        "polymorphic_discrimination_defaults",
        "rules"
      ],
      "properties": {
        "canonical_scalar_mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scalarMapping"
          },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": [
                  "contract_type"
                ],
                "properties": {
                  "contract_type": {
                    "const": "uuid"
                  }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "required": [
                  "contract_type"
                ],
                "properties": {
                  "contract_type": {
                    "const": "decimal"
                  },
                  "frontend_transport_number_forbidden": {
                    "const": true
                  }
                }
              }
            }
          ]
        },
        "polymorphic_discrimination_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "discriminator_field_name",
            "discriminator_location",
            "mapping_strategy",
            "openapi_strategy",
            "backend_strategy",
            "frontend_strategy",
            "db_strategy",
            "implicit_subclass_inference_forbidden",
            "undeclared_discriminator_values_forbidden"
          ],
          "properties": {
            "discriminator_field_name": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "discriminator_location": {
              "type": "string",
              "enum": [
                "payload_root",
                "payload_nested"
              ]
            },
            "mapping_strategy": {
              "type": "string",
              "enum": [
                "explicit_mapping_only"
              ]
            },
            "openapi_strategy": {
              "type": "string",
              "enum": [
                "oneOf_with_required_discriminator",
                "anyOf_with_required_discriminator"
              ]
            },
            "backend_strategy": {
              "type": "string",
              "enum": [
                "pydantic_discriminated_union"
              ]
            },
            "frontend_strategy": {
              "type": "string",
              "enum": [
                "typescript_discriminated_union"
              ]
            },
            "db_strategy": {
              "type": "string",
              "enum": [
                "explicit_declared_inheritance_only",
                "single_table_inheritance",
                "class_table_inheritance",
                "concrete_table_inheritance"
              ]
            },
            "implicit_subclass_inference_forbidden": {
              "const": true
            },
            "undeclared_discriminator_values_forbidden": {
              "const": true
            }
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ruleObject"
          },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": [
                  "rule_id",
                  "checker_id"
                ],
                "properties": {
                  "rule_id": {
                    "const": "TYPE-006"
                  },
                  "checker_id": {
                    "const": "check_polymorphic_discriminator_strategy_is_canonical"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "document_shape_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": [
              "rule_id",
              "checker_id"
            ],
            "properties": {
              "rule_id": {
                "const": "DOC-001"
              },
              "checker_id": {
                "const": "check_required_documents_exist"
              }
            }
          }
        }
      ]
    },
    "cross_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "event_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "projection_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": [
              "rule_id",
              "checker_id"
            ],
            "properties": {
              "rule_id": {
                "const": "PROJ-010"
              },
              "checker_id": {
                "const": "check_projection_accumulator_fields_declare_sequencing_dependency"
              }
            }
          }
        }
      ]
    },
    "side_effect_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": [
              "rule_id",
              "checker_id"
            ],
            "properties": {
              "rule_id": {
                "const": "SE-012"
              },
              "checker_id": {
                "const": "check_side_effect_predicate_manifest_is_present"
              }
            }
          }
        }
      ]
    },
    "concurrency_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "ui_state_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "time_determinism_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "test_scenario_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "stub_anchor_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "handoff_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "restriction_prompt_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": [
              "rule_id",
              "checker_id"
            ],
            "properties": {
              "rule_id": {
                "const": "RP-004"
              },
              "checker_id": {
                "const": "check_prompt_textual_compliance_with_constitution"
              }
            }
          }
        }
      ]
    },
    "diff_validation_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleObject"
      }
    },
    "waiver_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waivers_allowed",
        "waiver_file",
        "requirements",
        "restrictions"
      ],
      "properties": {
        "waivers_allowed": {
          "type": "boolean"
        },
        "waiver_file": {
          "const": "_reports/WAIVERS.yaml"
        },
        "requirements": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "waiver_id",
              "rule_id",
              "justification",
              "owner",
              "expiry_date",
              "approved_by"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "waiver_id"
              }
            },
            {
              "contains": {
                "const": "rule_id"
              }
            },
            {
              "contains": {
                "const": "justification"
              }
            },
            {
              "contains": {
                "const": "owner"
              }
            },
            {
              "contains": {
                "const": "expiry_date"
              }
            },
            {
              "contains": {
                "const": "approved_by"
              }
            }
          ]
        },
        "restrictions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cannot_waive"
          ],
          "properties": {
            "cannot_waive": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/ruleId"
              },
              "allOf": [
                {
                  "contains": {
                    "const": "DOC-001"
                  }
                },
                {
                  "contains": {
                    "const": "DOC-003"
                  }
                },
                {
                  "contains": {
                    "const": "DOC-004"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-001"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-002"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-003"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-004"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-005"
                  }
                },
                {
                  "contains": {
                    "const": "TYPE-006"
                  }
                },
                {
                  "contains": {
                    "const": "X-001"
                  }
                },
                {
                  "contains": {
                    "const": "X-002"
                  }
                },
                {
                  "contains": {
                    "const": "X-003"
                  }
                },
                {
                  "contains": {
                    "const": "X-004"
                  }
                },
                {
                  "contains": {
                    "const": "X-008"
                  }
                },
                {
                  "contains": {
                    "const": "X-010"
                  }
                },
                {
                  "contains": {
                    "const": "X-012"
                  }
                },
                {
                  "contains": {
                    "const": "X-015"
                  }
                },
                {
                  "contains": {
                    "const": "X-016"
                  }
                },
                {
                  "contains": {
                    "const": "X-017"
                  }
                },
                {
                  "contains": {
                    "const": "X-018"
                  }
                },
                {
                  "contains": {
                    "const": "X-019"
                  }
                },
                {
                  "contains": {
                    "const": "STUB-001"
                  }
                },
                {
                  "contains": {
                    "const": "STUB-002"
                  }
                },
                {
                  "contains": {
                    "const": "HO-002"
                  }
                },
                {
                  "contains": {
                    "const": "RP-001"
                  }
                },
                {
                  "contains": {
                    "const": "RP-002"
                  }
                },
                {
                  "contains": {
                    "const": "RP-003"
                  }
                },
                {
                  "contains": {
                    "const": "RP-004"
                  }
                },
                {
                  "contains": {
                    "const": "TIME-002"
                  }
                },
                {
                  "contains": {
                    "const": "EV-008"
                  }
                },
                {
                  "contains": {
                    "const": "PROJ-006"
                  }
                },
                {
                  "contains": {
                    "const": "PROJ-010"
                  }
                },
                {
                  "contains": {
                    "const": "SE-006"
                  }
                },
                {
                  "contains": {
                    "const": "SE-009"
                  }
                },
                {
                  "contains": {
                    "const": "SE-010"
                  }
                },
                {
                  "contains": {
                    "const": "SE-011"
                  }
                },
                {
                  "contains": {
                    "const": "SE-012"
                  }
                }
              ]
            }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_reports",
        "required_machine_summary_fields",
        "blocking_policy"
      ],
      "properties": {
        "required_reports": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "allOf": [
            {
              "contains": {
                "const": "_reports/cross_lint_report.json"
              }
            },
            {
              "contains": {
                "const": "_reports/cross_lint_report.md"
              }
            }
          ]
        },
        "required_machine_summary_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "status",
              "module_id",
              "checked_documents",
              "errors",
              "warnings",
              "passed_rules",
              "waived_rules",
              "snapshot_hash"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "status"
              }
            },
            {
              "contains": {
                "const": "module_id"
              }
            },
            {
              "contains": {
                "const": "checked_documents"
              }
            },
            {
              "contains": {
                "const": "errors"
              }
            },
            {
              "contains": {
                "const": "warnings"
              }
            },
            {
              "contains": {
                "const": "passed_rules"
              }
            },
            {
              "contains": {
                "const": "waived_rules"
              }
            },
            {
              "contains": {
                "const": "snapshot_hash"
              }
            }
          ]
        },
        "blocking_policy": {
          "$ref": "#/$defs/blockingPolicy"
        }
      }
    }
  }
}