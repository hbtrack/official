{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hbtrack:schema:execution-bindings:1.0.1",
  "title": "HB Track Execution Bindings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "defaults",
    "steps",
    "prohibited_keys",
    "binding_integrity"
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stepId": {
      "type": "string",
      "pattern": "^[A-Z]{3,}-EXEC-\\d{3}$"
    },
    "operationId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:__[a-z0-9]+)+$"
    },
    "checkerId": {
      "type": "string",
      "pattern": "^check_[a-z0-9_]+$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "symbolId": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "invariantId": {
      "type": "string",
      "pattern": "^INV-[A-Z]+-\\d{3}$"
    },
    "prohibitedKey": {
      "type": "string",
      "enum": [
        "bypass_db_nullability",
        "bypass_locking",
        "bypass_migrations",
        "bypass_invariants",
        "bypass_side_effect_policy",
        "allow_out_of_scope_write",
        "allow_new_public_symbols",
        "override_fail_closed",
        "override_constitution",
        "disable_checker",
        "waive_non_waivable_rule"
      ]
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "module_id",
        "version",
        "status",
        "authority_level",
        "constitution_version"
      ],
      "properties": {
        "document_id": { "type": "string", "pattern": "^EXECUTION-BINDINGS-[A-Z0-9_\\-]+$" },
        "module_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_\\-]+$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "status": { "type": "string", "enum": ["DRAFT", "FINAL_DRAFT", "APPROVED"] },
        "authority_level": { "type": "string", "enum": ["EXECUTIONAL_INPUT"] },
        "generated_by": { "type": "string" },
        "constitution_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "allow_new_public_symbols",
        "allow_out_of_scope_paths",
        "allow_constitution_override",
        "required_execution_mode"
      ],
      "properties": {
        "fail_closed": { "const": true },
        "allow_new_public_symbols": { "const": false },
        "allow_out_of_scope_paths": { "const": false },
        "allow_constitution_override": { "const": false },
        "required_execution_mode": { "const": "deterministic_only" }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "sequence",
          "step_type",
          "operation_id",
          "traceability_ref",
          "target_paths",
          "allowed_symbols",
          "required_checker_ids",
          "execution_flags"
        ],
        "properties": {
          "step_id": { "$ref": "#/$defs/stepId" },
          "sequence": { "type": "integer", "minimum": 1 },
          "step_type": { "type": "string", "enum": ["generate", "implement", "verify"] },
          "operation_id": { "$ref": "#/$defs/operationId" },
          "traceability_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["operation_id", "symbol_ids", "invariant_ids"],
            "properties": {
              "operation_id": { "$ref": "#/$defs/operationId" },
              "symbol_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/symbolId" },
                "uniqueItems": true
              },
              "invariant_ids": {
                "type": "array",
                "items": { "$ref": "#/$defs/invariantId" },
                "uniqueItems": true
              }
            }
          },
          "target_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/path" },
            "uniqueItems": true
          },
          "allowed_symbols": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/symbolId" },
            "uniqueItems": true
          },
          "required_checker_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/checkerId" },
            "uniqueItems": true
          },
          "execution_flags": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "requires_hash_match",
              "requires_structural_guard",
              "requires_ast_validation",
              "replay_allowed"
            ],
            "properties": {
              "requires_hash_match": { "type": "boolean" },
              "requires_structural_guard": { "type": "boolean" },
              "requires_ast_validation": { "type": "boolean" },
              "replay_allowed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "prohibited_keys": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/prohibitedKey"
      },
      "allOf": [
        { "contains": { "const": "bypass_db_nullability" } },
        { "contains": { "const": "bypass_locking" } },
        { "contains": { "const": "bypass_migrations" } },
        { "contains": { "const": "bypass_invariants" } },
        { "contains": { "const": "bypass_side_effect_policy" } },
        { "contains": { "const": "allow_out_of_scope_write" } },
        { "contains": { "const": "allow_new_public_symbols" } },
        { "contains": { "const": "override_fail_closed" } },
        { "contains": { "const": "override_constitution" } },
        { "contains": { "const": "disable_checker" } },
        { "contains": { "const": "waive_non_waivable_rule" } }
      ]
    },
    "binding_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_steps_must_have_traceability_ref",
        "all_step_paths_must_be_in_handoff_scope",
        "all_symbols_must_exist_in_traceability",
        "all_checker_ids_must_exist_in_constitution",
        "duplicate_step_ids_forbidden",
        "duplicate_sequence_forbidden"
      ],
      "properties": {
        "all_steps_must_have_traceability_ref": { "const": true },
        "all_step_paths_must_be_in_handoff_scope": { "const": true },
        "all_symbols_must_exist_in_traceability": { "const": true },
        "all_checker_ids_must_exist_in_constitution": { "const": true },
        "duplicate_step_ids_forbidden": { "const": true },
        "duplicate_sequence_forbidden": { "const": true }
      }
    }
  }
}
