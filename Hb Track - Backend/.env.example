# ============================================================================
# HB Track - Backend Configuration
# Configuração otimizada para ambiente local de desenvolvimento
# ============================================================================

# Environment
ENV=local

# ============================================================================
# Database dockerized (Hb Track - localhost:5433)
# ============================================================================

# APP (FastAPI)
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5433/your_db_name

# MIGRATIONS / SEED (Alembic + psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://your_db_user:your_db_password@localhost:5433/your_db_name



# ============================================================================
# Database settings
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
PGDATA=/var/lib/postgresql/data

# ============================================================================
# Pool settings (otimizado para suportar múltiplas requisições paralelas)
# ============================================================================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT=45
DB_POOL_RECYCLE=1800

# ============================================================================
# Security (JWT próprio)
# ============================================================================
# Use a cryptographically secure random string of at least 32 characters.
# Exemplo: gerado com `openssl rand -hex 32` ou equivalente.
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30

# ============================================================================
# API
# ============================================================================
API_DESCRIPTION=Sistema de Gestão de Handebol
API_TITLE=HB Tracking API
API_DESCRIPTION=Sistema de Gestao de Handebol

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000

# CORS
# Origem local e 127 para o frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true


# ============================================================================
# Cache (TTL em segundos - reduz queries no Free tier)
# ============================================================================
CACHE_TTL_VINCULOS=300
CACHE_TTL_PERMISSOES=300

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Cloudinary (para upload de imagens)
# ============================================================================  
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=your_upload_preset
CLOUDINARY_ASSET=https://res.cloudinary.com/your_cloud_name/image/upload/t_profile_avatar/cld-sample

# ============================================================================
# Resend (envio de emails transacionais)
# ============================================================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_from_email
RESEND_FROM_NAME=Your App Name

# RESEND_REPLY_TO=your_reply_to_email

# ============================================================================
# Google Gemini AI (para parsing de PDFs de competição)
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key

# ============================================================================
# Celery + Redis (Step 18 - Alertas e Sugestões Automáticas)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=America/Sao_Paulo
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=300
FLOWER_BASIC_AUTH=your_username:your_password

# Flower (Celery monitoring UI)
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:your_password