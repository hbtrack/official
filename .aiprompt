# HB Track — AI Agent Configuration
# YAML format for Cursor, Aider, and local AI tools
# Defines SSOT, constraints, and default prompts

version: "1.0.0"
project: "HB Track — Handball Management System"
repository: "https://github.com/HB-Track/backend"
language: ["python", "typescript", "powershell", "sql"]

# Authority hierarchy (SSOT precedence)
authority:
  - name: "Database Schema"
    source: "docs/_generated/_core/schema.sql"
    trust: 100
    updateFrequency: "after migrations"
  
  - name: "OpenAPI Contract"
    source: "docs/_generated/_core/openapi.json"
    trust: 95
    updateFrequency: "after code changes"
  
  - name: "Canonical Docs"
    source: "docs/_canon/"
    trust: 90
    updateFrequency: "on architectural changes"
  
  - name: "ADRs"
    source: "docs/ADR/"
    trust: 85
    updateFrequency: "when decisions are made"

# Default constraints (enforce for all agents)
constraints:
  - "PowerShell 5.1 mandatory (no pwsh/bash)"
  - "Working directory: C:\\HB TRACK"
  - "No temporary files in repo"
  - "Stop-on-first-failure policy"
  - "Capture $LASTEXITCODE immediately"
  - "No git reset --hard without explicit approval"

# Default context files to load
context:
  critical:
    - "docs/_ai/_INDEX.md"
    - "docs/_canon/00_START_HERE.md"
    - "docs/_canon/01_AUTHORITY_SSOT.md"
    - ".github/copilot-instructions.md"
  
  recommended:
    - "docs/_canon/02_CONTEXT_MAP.md"
    - "docs/_canon/03_WORKFLOWS.md"
    - "docs/ADR/_INDEX_ADR.md"

# Exclusions (performance + security)
exclude:
  - ".git/"
  - "node_modules/"
  - "__pycache__/"
  - ".env"
  - "secrets/"
  - "docs/_generated/_scratch/"
  - "backup-dados-criticos/"

# Task routing (which agent handles which requests)
routing:
  "code review": "docs/_ai/_prompts/HB_TRACK_CODE_REVIEW_AGENT.md"
  "models validation": "docs/_ai/_specs/models-validation-spec.md"
  "git operations": "docs/_canon/10_GIT_PR_MERGE_WORKFLOW.md"
  "database schema": "docs/_canon/04_SOURCES_GENERATED.md"

# Exit code mapping
exitCodes:
  0: "success"
  1: "crash / runtime error"
  2: "parity violation"
  3: "guard violation"
  4: "requirements violation"

# Handshake verification (enforce on session start)
handshake:
  required: true
  template: ".github/copilot-handshake.md"
  acknowledgements:
    - "SSOT files read"
    - "Constraints acknowledged"
    - "Determinism commitment"
    - "Gate validation rules"

# Quality gates
quality:
  python:
    maxComplexity: 6
    maxLineLengthFunction: 50
    maxLineLengthClass: 200
    coverage: 75
  
  typescript:
    strict: true
    enforcedRules: ["no-any", "no-as-any"]
  
  powershell:
    strictMode: "Latest"
    bannedCommands: ["Invoke-Expression", "iex"]

# Tool configurations
tools:
  radon:
    thresholds:
      A: 1-5
      B: 6-10
      C: 11-20
      D: 21-30
  
  lizard:
    maxComplexity: 6
    maxNestedDepth: 2
  
  git:
    requireCommitMessages: true
    enforceConventionalCommits: true

# AI model defaults
models:
  default: "claude-haiku-4.5"
  codeReview: "claude-opus-4"
  architecture: "claude-opus-4"

# Logging and output
logging:
  level: "INFO"
  format: "HB Track — [%(levelname)s] %(message)s"
  destination: "stdout + docs/_generated/_scratch/agent.log"

# End of .aiprompt
