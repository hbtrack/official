# .copilotignore — GitHub Copilot Indexing Exclusions
# Patterns matched are excluded from Copilot's code intelligence index
# Use standard glob patterns

# Version control
.git/
.gitignore

# Dependencies and build artifacts
node_modules/
venv/
env/
.venv
__pycache__/
*.pyc
*.pyo
build/
dist/
*.egg-info/

# IDE and temporary files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Sensitive files (CRITICAL)
.env
.env.local
.env.*.local
.env.production.local
secrets/
credentials/
*.pem
*.key
*.pfx
id_ed25519
id_ed25519.pub

# Generated code and artifacts
docs/_generated/
docs/_generated/_scratch/
.next/
out/

# Large dumps and backups
backup-dados-criticos/
versions_backup_*/
*.dump
*.sql (except schema.sql)

# Test and temporary files
__tests__/
test_*.py
*.test.js
*.test.ts
temp_*.txt
tmp_*.txt
.pytest_cache/
.coverage
htmlcov/

# Project-specific
dsa/
node_modules/
front-end/node_modules/
.AppleDouble
.LSOverride

# End of .copilotignore
