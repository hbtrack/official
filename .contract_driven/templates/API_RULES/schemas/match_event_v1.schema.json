{
    "$id": "https://api.hbtrack.com/schemas/match_event_v1.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "HB Track Match Event v1",
    "description": "Canonical match event schema. This is the authoritative domain schema used in both sync result and event publication.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "matchEventId",
        "matchId",
        "eventType",
        "occurredAt",
        "periodNumber",
        "sequenceNumber",
        "provenance"
    ],
    "properties": {
        "matchEventId": {
            "type": "string",
            "format": "uuid",
            "description": "Canonical immutable match event identifier generated by HB Track.",
            "x-hb-visibility": [
                "sync",
                "event"
            ],
            "x-hb-authority": "server"
        },
        "matchId": {
            "type": "string",
            "format": "uuid",
            "description": "Canonical match identifier.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "eventType": {
            "type": "string",
            "enum": [
                "GOAL",
                "YELLOW_CARD",
                "RED_CARD",
                "TWO_MINUTES",
                "PENALTY_AWARDED",
                "PENALTY_SCORED",
                "PENALTY_MISSED",
                "TURNOVER",
                "STEAL",
                "BLOCK",
                "SAVE",
                "TIMEOUT",
                "SUBSTITUTION",
                "PERIOD_STARTED",
                "PERIOD_ENDED",
                "MATCH_STARTED",
                "MATCH_ENDED",
                "EVENT_CORRECTED",
                "EVENT_CANCELLED"
            ],
            "description": "Canonical domain event type.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "occurredAt": {
            "type": "string",
            "format": "date-time",
            "description": "Domain time: when the match event actually occurred. Never a transport timestamp.",
            "x-hb-visibility": [
                "sync",
                "event"
            ],
            "x-hb-temporal-role": "domain_time"
        },
        "athleteId": {
            "type": "string",
            "format": "uuid",
            "description": "Canonical athlete identifier when the event is attributable to one athlete.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "teamId": {
            "type": "string",
            "format": "uuid",
            "description": "Canonical team identifier when the event is attributable to one team.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "periodNumber": {
            "type": "integer",
            "minimum": 1,
            "description": "Match period number in which the event occurred.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "sequenceNumber": {
            "type": "integer",
            "minimum": 1,
            "description": "Canonical ordering number within the match event stream.",
            "x-hb-visibility": [
                "sync",
                "event"
            ],
            "x-hb-authority": "server"
        },
        "clockSeconds": {
            "type": "number",
            "minimum": 0,
            "description": "Elapsed clock time in seconds (decimal) within the relevant match scope.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "videoTimestampSeconds": {
            "type": "number",
            "minimum": 0,
            "description": "Video-aligned timestamp in seconds (decimal) when available.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "correctionOfMatchEventId": {
            "type": "string",
            "format": "uuid",
            "description": "References the original event when this event is a correction or cancellation.",
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        },
        "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "sourceType",
                "sourceSystem",
                "normalizationVersion"
            ],
            "properties": {
                "sourceType": {
                    "type": "string",
                    "enum": [
                        "MANUAL",
                        "VIDEO_AI",
                        "EXTERNAL_PROVIDER",
                        "CSV_IMPORT",
                        "FEDERATION_FEED"
                    ],
                    "x-hb-visibility": [
                        "sync",
                        "event"
                    ]
                },
                "sourceSystem": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]*$",
                    "x-hb-visibility": [
                        "sync",
                        "event"
                    ]
                },
                "sourceRecordId": {
                    "type": "string",
                    "x-hb-visibility": [
                        "sync"
                    ]
                },
                "observedAt": {
                    "type": "string",
                    "format": "date-time",
                    "x-hb-visibility": [
                        "sync",
                        "event"
                    ]
                },
                "confidenceRatio": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Confidence ratio (0-1 scale) for AI-generated or uncertain data.",
                    "x-hb-visibility": [
                        "sync",
                        "event"
                    ]
                },
                "normalizationVersion": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*$",
                    "x-hb-visibility": [
                        "sync",
                        "event"
                    ]
                },
                "provenanceMetadata": {
                    "type": "object",
                    "additionalProperties": true,
                    "x-hb-visibility": [
                        "sync"
                    ]
                }
            },
            "x-hb-visibility": [
                "sync",
                "event"
            ]
        }
    }
}