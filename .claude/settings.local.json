{
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(grep:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./config/credentials.json)"
    ],
    "disableBypassPermissionsMode": "disable"
  }
}
